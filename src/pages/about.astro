---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { BADGE_COLORS } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

---

<!doctype html>
<html lang="nl">
  <head>
    <BaseHead title="Over mij" description="Over Niels Janssen" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <Header />

    <div class="hero">
      <div class="hero-inner">
        <div class="eyebrow">Over mij</div>
        <h1 class="hero-title">Niels Janssen</h1>
        <p class="hero-subtitle">Cloud & Cybersecurity</p>
      </div>
    </div>

    <section class="section">
      <div class="prose">
        <p>
          <p>Van jongsaf was ik bevoordeeld dat mijn ouders een computer nodig hadden voor de administratie van hun bedrijf. <br>
          Geïntrigeerd door deze zwarte doos in de leefruimte begon ik al snel te experimenteren met de computer, wat leidde tot een passie.<br>
          Mijn ontdekkingstochten veroorzaakten al eens technische problemen, maar dat creëerde voor mij kansen om te leren wat heeft bijgedragen aan mijn probleemoplossende mindset.
        </p>
      </div>
    </section>

    <Footer />
  </body>
</html>