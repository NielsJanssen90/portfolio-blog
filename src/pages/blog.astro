---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="nl">
  <head>
    <BaseHead title="Blog" description="Alle blog posts" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <Header />

    <div class="hero">
      <div class="hero-inner">
        <div class="eyebrow">Blog</div>
        <h1 class="hero-title">Alle posts</h1>
        <p class="hero-subtitle">Projecten, inzichten en ervaringen uit vier jaar Cloud & Cybersecurity.</p>
      </div>
    </div>

    <section class="section">
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-card-top">
              <span class={`badge ${BADGE_COLORS[post.data.category] || 'badge-green'}`}>
                {post.data.category}</span>
            </div>
            <div class="post-card-title">{post.data.title}</div>
            <p class="post-card-desc">{post.data.description}</p>
            <div class="post-card-footer">
              <span class="post-date">
                {post.data.pubDate.toLocaleDateString('nl-BE', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <span class="post-arrow">Lees meer →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <Footer />
  </body>
</html>