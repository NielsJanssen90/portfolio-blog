---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const colors: Record<string, string> = {
  automation:     'green',
  infrastructure: 'blue',
  security:       'red',
  reflectie:      'amber',
  algemeen:       'green',
};
---

<Base title="Blog — Niels Janssen" activePage="blog">

  <div class="hero">
    <div class="hero-inner">
      <div class="eyebrow">Stage 2026</div>
      <h1 class="hero-title">
        Weekelijkse <em>updates</em><br/>van het project
      </h1>
      <p class="hero-subtitle">
        16 weken network automation bij 
      </p>
      <div class="hero-meta">
        <div class="hero-meta-item">
          <label>Project</label>
          <span>Bluenet</span>
        </div>
        <div class="hero-meta-item">
          <label>Posts</label>
          <span>{posts.length} gepubliceerd</span>
        </div>
      </div>
    </div>
  </div>

  <section class="listing">
    <div class="listing-inner">
      {posts.length === 0
        ? <p class="empty">Nog geen posts — eerste post komt eraan.</p>
        : (
          <div class="posts-grid">
            {posts.map(post => {
              const c = colors[post.data.category];
              const d = post.data.pubDate.toLocaleDateString('nl-BE', { year:'numeric', month:'short', day:'numeric' });
              return (
                <a href={`/blog/${post.slug}`} class="post-card">
                  <div class="post-card-top">
                    <span class={`badge badge-${c}`}>{post.data.category}</span>
                    {post.data.week && <span class="week-label">Week {post.data.week}</span>}
                  </div>
                  <div class="post-card-title">{post.data.title}</div>
                  <div class="post-card-desc">{post.data.description}</div>
                  {post.data.tags.length > 0 && (
                    <div class="tags">
                      {post.data.tags.slice(0, 4).map(t => <span class="tag">{t}</span>)}
                    </div>
                  )}
                  <div class="post-card-footer">
                    <span class="post-date">{d}</span>
                    <span class="post-arrow">Lees meer →</span>
                  </div>
                </a>
              );
            })}
          </div>
        )
      }
    </div>
  </section>

</Base>

<style>
.listing       { padding: 60px 60px 100px; }
.listing-inner { max-width: 1100px; margin: 0 auto; }
.empty { color: var(--muted); padding: 60px 0; text-align: center; }
@media (max-width: 768px) {
  .listing { padding: 40px 24px 80px; }
}
</style>
