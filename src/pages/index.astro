---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const colors: Record<string, string> = {
  automation:     'green',
  infrastructure: 'blue',
  security:       'red',
  reflectie:      'amber',
  algemeen:       'green',
};
---

<!doctype html>
<html lang="nl">
  <head>
    <BaseHead title="Home" description="blogtest" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <Header />

    <div class="hero">
      <div class="hero-inner">
        <div class="eyebrow">Cloud & Cybersecurity</div>
        <h1 class="hero-title">Niels Janssen</h1>
        <p class="hero-subtitle">Vier jaar bouwen aan veilige en betrouwbare IT-infrastructuur.</p>
      </div>
    </div>


    <section class="section">
      <div class="section-title">Laatste projecten</div>

      <div class="posts-grid">
        <a href="#" class="post-card">
          <div class="post-card-top">
            <span class="badge badge-green">Stage Project</span>
            <span class="week-label">16 weken</span>
          </div>
          <div class="post-card-title">Network Automation met Ansible, SemaphoreUI en Gitlab</div>
          <p class="post-card-desc">Read - Backup - Write operations met ingebouwde veiligheden en een gelaagd uitrol process.</p>
          <div class="tags">
            <span class="tag">Ansible</span>
            <span class="tag">Semaphore</span>
            <span class="tag">Gitlab</span>
          </div>
          <div class="post-card-footer">
            <span class="post-date">2026</span>
            <span class="post-arrow">Lees meer →</span>
          </div>
        </a>
      </div>

      <div class="posts-grid">
        <a href="#" class="post-card">
          <div class="post-card-top">
            <span class="badge badge-green">Stage Project</span>
            <span class="week-label">16 weken</span>
          </div>
          <div class="post-card-title">Network Automation met Ansible, SemaphoreUI en Gitlab</div>
          <p class="post-card-desc">Read - Backup - Write operations met ingebouwde veiligheden en een gelaagd uitrol process.</p>
          <div class="tags">
            <span class="tag">Ansible</span>
            <span class="tag">Semaphore</span>
            <span class="tag">Gitlab</span>
          </div>
          <div class="post-card-footer">
            <span class="post-date">2026</span>
            <span class="post-arrow">Lees meer →</span>
          </div>
        </a>
      </div>

    </section>
